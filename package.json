{
  "name": "productexplorer",
  "main": "index.js",
  "version": "1.0.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --clean --platform android",
    "prebuild:ios": "expo prebuild --clean --platform ios",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix",
    "test": "jest --watchman=false",
    "test:watch": "jest --watch --watchman=false",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "commit": "git-cz",
    "prepare": "husky",
    "e2e:test:ios:debug": "detox test --configuration ios.sim.debug",
    "e2e:build:ios:debug": "detox build --configuration ios.sim.debug"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "8.0.0-alpha.16",
    "@react-navigation/elements": "3.0.0-alpha.15",
    "@react-navigation/native": "8.0.0-alpha.14",
    "@react-navigation/native-stack": "8.0.0-alpha.16",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "expo": "~55.0.5",
    "expo-build-properties": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.7",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.7",
    "expo-localization": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.9",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.5",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.10",
    "detox": "^20.47.0",
    "eslint": "^9.39.3",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "jest": "^29",
    "jest-expo": "^55.0.9",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2",
    "react-test-renderer": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "<rootDir>/e2e/"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,mjs}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true
}
